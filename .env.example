PORT=3000
URJA_BASE_URL=https://urja-ops.flockenergy.tech
URJA_USERNAME=replace-with-portal-username
URJA_PASSWORD=replace-with-portal-password
URJA_TIMEOUT_MS=10000
URJA_RETRY_COUNT=1
URJA_LOGIN_PATH=/login
URJA_METER_LIST_PATH=/meters
URJA_METER_DETAIL_PATH=/meters/:id
URJA_CONSUMPTION_PATH=/meters/:id/consumption
URJA_HIERARCHY_PATH=/hierarchy
URJA_USERNAME_FIELD=username
URJA_PASSWORD_FIELD=password
LOG_LEVEL=info
